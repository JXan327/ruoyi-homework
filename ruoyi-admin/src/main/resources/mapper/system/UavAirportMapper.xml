<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.UavAirportMapper">
    
    <resultMap type="UavAirport" id="UavAirportResult">
        <result property="airportId"    column="airport_id"    />
        <result property="airportCode"    column="airport_code"    />
        <result property="airportName"    column="airport_name"    />
        <result property="airportType"    column="airport_type"    />
        <result property="province"    column="province"    />
        <result property="city"    column="city"    />
        <result property="district"    column="district"    />
        <result property="address"    column="address"    />
        <result property="longitude"    column="longitude"    />
        <result property="latitude"    column="latitude"    />
        <result property="altitude"    column="altitude"    />
        <result property="coverRadius"    column="cover_radius"    />
        <result property="maxUavCount"    column="max_uav_count"    />
        <result property="managerName"    column="manager_name"    />
        <result property="managerPhone"    column="manager_phone"    />
        <result property="status"    column="status"    />
        <result property="onlineStatus"    column="online_status"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectUavAirportVo">
        select airport_id, airport_code, airport_name, airport_type, province, city, district, address, longitude, latitude, altitude, cover_radius, max_uav_count, manager_name, manager_phone, status, online_status, remark, create_by, create_time, update_by, update_time, del_flag from uav_airport
    </sql>

    <select id="selectUavAirportList" parameterType="UavAirport" resultMap="UavAirportResult">
        <include refid="selectUavAirportVo"/>
        <where>  
            <if test="airportCode != null  and airportCode != ''"> and airport_code = #{airportCode}</if>
            <if test="airportName != null  and airportName != ''"> and airport_name like concat('%', #{airportName}, '%')</if>
            <if test="airportType != null  and airportType != ''"> and airport_type = #{airportType}</if>
            <if test="province != null  and province != ''"> and province = #{province}</if>
            <if test="city != null  and city != ''"> and city = #{city}</if>
            <if test="district != null  and district != ''"> and district = #{district}</if>
            <if test="address != null  and address != ''"> and address = #{address}</if>
            <if test="longitude != null "> and longitude = #{longitude}</if>
            <if test="latitude != null "> and latitude = #{latitude}</if>
            <if test="altitude != null "> and altitude = #{altitude}</if>
            <if test="coverRadius != null "> and cover_radius = #{coverRadius}</if>
            <if test="maxUavCount != null "> and max_uav_count = #{maxUavCount}</if>
            <if test="managerName != null  and managerName != ''"> and manager_name like concat('%', #{managerName}, '%')</if>
            <if test="managerPhone != null  and managerPhone != ''"> and manager_phone = #{managerPhone}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="onlineStatus != null  and onlineStatus != ''"> and online_status = #{onlineStatus}</if>
        </where>
    </select>
    
    <select id="selectUavAirportByAirportId" parameterType="Long" resultMap="UavAirportResult">
        <include refid="selectUavAirportVo"/>
        where airport_id = #{airportId}
    </select>

    <insert id="insertUavAirport" parameterType="UavAirport" useGeneratedKeys="true" keyProperty="airportId">
        insert into uav_airport
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="airportCode != null and airportCode != ''">airport_code,</if>
            <if test="airportName != null and airportName != ''">airport_name,</if>
            <if test="airportType != null">airport_type,</if>
            <if test="province != null">province,</if>
            <if test="city != null">city,</if>
            <if test="district != null">district,</if>
            <if test="address != null">address,</if>
            <if test="longitude != null">longitude,</if>
            <if test="latitude != null">latitude,</if>
            <if test="altitude != null">altitude,</if>
            <if test="coverRadius != null">cover_radius,</if>
            <if test="maxUavCount != null">max_uav_count,</if>
            <if test="managerName != null">manager_name,</if>
            <if test="managerPhone != null">manager_phone,</if>
            <if test="status != null">status,</if>
            <if test="onlineStatus != null">online_status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="airportCode != null and airportCode != ''">#{airportCode},</if>
            <if test="airportName != null and airportName != ''">#{airportName},</if>
            <if test="airportType != null">#{airportType},</if>
            <if test="province != null">#{province},</if>
            <if test="city != null">#{city},</if>
            <if test="district != null">#{district},</if>
            <if test="address != null">#{address},</if>
            <if test="longitude != null">#{longitude},</if>
            <if test="latitude != null">#{latitude},</if>
            <if test="altitude != null">#{altitude},</if>
            <if test="coverRadius != null">#{coverRadius},</if>
            <if test="maxUavCount != null">#{maxUavCount},</if>
            <if test="managerName != null">#{managerName},</if>
            <if test="managerPhone != null">#{managerPhone},</if>
            <if test="status != null">#{status},</if>
            <if test="onlineStatus != null">#{onlineStatus},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateUavAirport" parameterType="UavAirport">
        update uav_airport
        <trim prefix="SET" suffixOverrides=",">
            <if test="airportCode != null and airportCode != ''">airport_code = #{airportCode},</if>
            <if test="airportName != null and airportName != ''">airport_name = #{airportName},</if>
            <if test="airportType != null">airport_type = #{airportType},</if>
            <if test="province != null">province = #{province},</if>
            <if test="city != null">city = #{city},</if>
            <if test="district != null">district = #{district},</if>
            <if test="address != null">address = #{address},</if>
            <if test="longitude != null">longitude = #{longitude},</if>
            <if test="latitude != null">latitude = #{latitude},</if>
            <if test="altitude != null">altitude = #{altitude},</if>
            <if test="coverRadius != null">cover_radius = #{coverRadius},</if>
            <if test="maxUavCount != null">max_uav_count = #{maxUavCount},</if>
            <if test="managerName != null">manager_name = #{managerName},</if>
            <if test="managerPhone != null">manager_phone = #{managerPhone},</if>
            <if test="status != null">status = #{status},</if>
            <if test="onlineStatus != null">online_status = #{onlineStatus},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where airport_id = #{airportId}
    </update>

    <delete id="deleteUavAirportByAirportId" parameterType="Long">
        delete from uav_airport where airport_id = #{airportId}
    </delete>

    <delete id="deleteUavAirportByAirportIds" parameterType="String">
        delete from uav_airport where airport_id in 
        <foreach item="airportId" collection="array" open="(" separator="," close=")">
            #{airportId}
        </foreach>
    </delete>
</mapper>